{
  "name": "exarchos",
  "description": "Structure for agentic development — durable SDLC workflows with convergence gates, agent teams, and full audit trail.",
  "version": "2.3.4",
  "author": {
    "name": "Levelup Software"
  },
  "homepage": "https://github.com/lvlup-sw/exarchos",
  "repository": "https://github.com/lvlup-sw/exarchos",
  "license": "Apache-2.0",
  "keywords": [
    "workflow",
    "sdlc",
    "event-sourcing",
    "quality-gates",
    "agent-teams",
    "durable-workflows",
    "audit-trail",
    "code-review"
  ],
  "commands": "./commands/",
  "skills": "./skills/",
  "mcpServers": {
    "exarchos": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/dist/exarchos-mcp.js"
      ],
      "env": {
        "WORKFLOW_STATE_DIR": "~/.claude/workflow-state",
        "EXARCHOS_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}"
      }
    }
  }
}
