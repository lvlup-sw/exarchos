{
  "hooks": {
    "PreCompact": [{
      "matcher": "auto",
      "hooks": [{
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/exarchos.js\" pre-compact",
        "timeout": 30,
        "statusMessage": "Saving workflow checkpoint..."
      }]
    }],
    "SessionStart": [{
      "matcher": "startup|resume",
      "hooks": [{
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/exarchos.js\" session-start --plugin-root \"${CLAUDE_PLUGIN_ROOT}\"",
        "timeout": 10,
        "statusMessage": "Checking for active workflows..."
      }]
    }],
    "PreToolUse": [{
      "matcher": "mcp__(plugin_exarchos_)?exarchos__.*",
      "hooks": [{
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/exarchos.js\" guard",
        "timeout": 5
      }]
    }],
    "TaskCompleted": [{
      "hooks": [{
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/exarchos.js\" task-gate",
        "timeout": 120,
        "statusMessage": "Running quality gates..."
      }]
    }],
    "TeammateIdle": [{
      "hooks": [{
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/exarchos.js\" teammate-gate",
        "timeout": 120,
        "statusMessage": "Verifying teammate work..."
      }]
    }],
    "SubagentStart": [{
      "hooks": [{
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/exarchos.js\" subagent-context",
        "timeout": 5
      }]
    }],
    "SubagentStop": [{
      "matcher": "exarchos-implementer|exarchos-fixer",
      "hooks": [{
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/exarchos.js\" subagent-stop"
      }]
    }],
    "SessionEnd": [{
      "matcher": "auto",
      "hooks": [{
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/dist/exarchos.js\" session-end",
        "timeout": 30
      }]
    }]
  }
}
