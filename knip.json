{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/build-skills.ts",
    "src/install-skills.ts",
    "src/skills-guard.ts",
    "src/placeholder-lint.ts",
    "scripts/build-binary.ts",
    "scripts/*.test.ts"
  ],
  "project": [
    "src/**/*.ts",
    "scripts/**/*.ts"
  ],
  "ignore": [
    "dist/**",
    ".claude/**",
    "documentation/**",
    "packages/**",
    "renovate-config.js"
  ],
  "ignoreDependencies": [
    "tsx"
  ],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "servers/exarchos-mcp": {
      "entry": [
        "src/index.ts",
        "src/agents/generate-cc-agents.ts",
        "src/**/*.test.ts",
        "src/**/*.bench.ts",
        "src/__tests__/**/*.ts",
        "src/bench/**/*.ts",
        "src/benchmarks/**/*.ts",
        "src/evals/**/*.ts"
      ],
      "project": [
        "src/**/*.ts"
      ],
      "ignore": [
        "dist/**",
        "src/storage/__shims__/**",
        "src/event-store/__tests__/spawn-driver.ts",
        "src/telemetry/benchmarks/helpers.ts"
      ]
    }
  }
}
