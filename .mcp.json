{
  "mcpServers": {
    "exarchos": {
      "type": "stdio",
      "command": "bun",
      "args": ["run", "./dist/exarchos-mcp.js"],
      "env": {
        "WORKFLOW_STATE_DIR": "~/.claude/workflow-state"
      }
    },
    "graphite": {
      "type": "stdio",
      "command": "gt",
      "args": ["mcp"]
    }
  }
}
